{
  "rewrites": [
    { "source": "/benat", "destination": "/Benat/index.html" },
    { "source": "/zigor", "destination": "/Zigor/index.html" },
    { "source": "/dani", "destination": "/Dani/index.html" },
    { "source": "/panel", "destination": "/panel/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ]
}
